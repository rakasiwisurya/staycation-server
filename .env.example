# ─────────────────────────────────────────────────────────────────────────────
# Staycation server configuration
# Copy to `.env` and fill in. The same file shape works for local and prod —
# only the values differ between the `main` (local) and `production` branches.
# ─────────────────────────────────────────────────────────────────────────────

# "development" locally, "production" on Render.
NODE_ENV=development

# Port the server listens on (Render injects its own PORT).
PORT=4000

# Public base URL of THIS server, no trailing slash. Used to build absolute
# URLs for locally stored images. On Render: https://your-app.onrender.com
SERVER_URL=http://localhost:4000

# MongoDB connection string.
#   local : mongodb://localhost:27017/db_staycation
#   atlas : mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/db_staycation
MONGODB_URI=mongodb://localhost:27017/db_staycation

# Image storage backend: "local" (disk) or "cloudinary".
STORAGE_DRIVER=local

# Secret used to sign admin session cookies — use a long random value in prod.
SESSION_SECRET=change-this-to-a-long-random-string

# Allowed browser origin(s) for the API, comma-separated.
# Leave empty to reflect any origin (handy for local dev).
#   local : http://localhost:5173
#   prod  : https://your-site.netlify.app
CLIENT_URL=http://localhost:5173

# Cloudinary credentials — only required when STORAGE_DRIVER=cloudinary.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=staycation
